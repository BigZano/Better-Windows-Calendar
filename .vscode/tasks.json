{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build (dev)",
            "type": "shell",
            "command": ".\\scripts\\build-dev.ps1",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": "$go"
        },
        {
            "label": "Build (release)",
            "type": "shell",
            "command": ".\\scripts\\build-windows.ps1",
            "group": "build",
            "presentation": {
                "reveal": "always"
            }
        },
        {
            "label": "Run tests",
            "type": "shell",
            "command": "go test ./...",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": "$go"
        }
    ]
}
